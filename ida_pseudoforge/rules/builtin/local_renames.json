        "text_contains": "CurrentThread"
      },
      "emit": {
        "kind": "rename",
        "rename_kind": "lvar",
        "target": "CurrentThread",
        "new_name": "currentThread",
        "source": "rule",
        "evidence": "KTHREAD pointer returned by KeGetCurrentThread"
      }
    },
