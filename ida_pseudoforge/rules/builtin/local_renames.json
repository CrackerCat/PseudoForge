    {
      "id": "builtin.pattern.input_length_copy",
      "phase": "rename",
      "priority": 80,
      "confidence": 0.93,
      "scope": {
        "text_contains": "(unsigned int)a3"
      },
      "match": {
        "assignment_regex": "\\b(?P<dst>[A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*\\(unsigned\\s+int\\)\\s*a3\\b"
      },
      "emit": {
        "kind": "rename",
        "rename_kind": "lvar",
        "target": "$dst",
        "new_name": "inputLength",
        "source": "rule",
        "evidence": "local is a 32-bit copy of SystemInformationLength"
      }
    },
    {
      "id": "builtin.pattern.info_class_copy",
      "phase": "rename",
      "priority": 80,
      "confidence": 0.97,
      "scope": {
        "text_contains": "(int)a1"
      },
      "match": {
        "assignment_regex": "\\b(?P<dst>[A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*\\(int\\)\\s*a1\\b"
