{
  "schema_version": 1,
  "id": "pseudoforge.builtin.local_renames",
  "description": "Builtin low-risk local rename rules mirrored from deterministic semantic and assignment patterns.",
  "rules": [
    {
      "id": "builtin.local.previous_mode_name",
      "phase": "rename",
      "priority": 90,
      "confidence": 0.99,
      "scope": {
        "lvars_any": ["PreviousMode"]
      },
      "match": {
        "text_contains": "PreviousMode"
      },
      "emit": {
        "kind": "rename",
        "rename_kind": "lvar",
        "target": "PreviousMode",
        "new_name": "previousMode",
        "source": "rule",
        "evidence": "Hex-Rays kept kernel PreviousMode casing"
      }
    },
    {
      "id": "builtin.local.current_thread_name",
      "phase": "rename",
      "priority": 90,
      "confidence": 0.99,
